{
  "manifest_version": 3,
  "name": "Super Tab Out",
  "version": "1.0.0",
  "description": "A customized new-tab dashboard that groups your open tabs by domain, with theme switching. Based on Tab Out by Zara Zhang (MIT).",
  "permissions": ["tabs", "storage", "tabGroups"],
  "chrome_url_overrides": { "newtab": "index.html" },
  "background": { "service_worker": "background.js" },
  "action": {
    "default_title": "Super Tab Out",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
